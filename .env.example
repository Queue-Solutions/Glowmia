NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
EMAIL_API_KEY=
EMAIL_FROM=Glowmia <glowmia.sa@hotmail.com>
EMAIL_TO=glowmia.sa@hotmail.com
NEWSLETTER_FROM_EMAIL=Glowmia <glowmia.sa@hotmail.com>
GLOWMIA_CONTACT_EMAIL=glowmia.sa@hotmail.com
REPLICATE_API_TOKEN=
REPLICATE_LLM_MODEL=
REPLICATE_IMAGE_MODEL=
CRON_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
NEXT_PUBLIC_SITE_URL=

# Checkout order email destination.
# Orders are sent through FormSubmit: https://formsubmit.co
CHECKOUT_EMAIL_TO=glowmia.sa@hotmail.com

# Required in Vercel production and preview deployments.
# Set this to the public FastAPI backend URL, for example:
# AGENT_BACKEND_URL=https://your-agent-backend.example.com
AGENT_BACKEND_URL=

# Optional backward-compatible alias for older environments.
# Prefer AGENT_BACKEND_URL for all new deployments.
# GLOWMIA_AGENT_API_URL=

# Optional browser-side direct backend URL.
# The current frontend uses /api/agent/*, so this is normally not required.
# NEXT_PUBLIC_AGENT_BACKEND_URL=

# Optional proxy timeout override in milliseconds.
# AGENT_PROXY_TIMEOUT_MS=20000

# Optional local development overrides for the bundled FastAPI runtime.
# GLOWMIA_AGENT_PYTHON=
# GLOWMIA_AGENT_RUNTIME_DIR=

# Backward-compatible fallback if your project still uses the older key name:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
